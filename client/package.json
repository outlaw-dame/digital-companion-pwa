{
  "name": "ane-client",
  "version": "0.2.0",
  "description": "Digital Companion PWA - Frontend with Framework7/Vue architecture",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    
    "test:a11y": "playwright test tests/e2e/accessibility/",
    "test:a11y:headed": "playwright test tests/e2e/accessibility/ --headed",
    
    "test:visual": "playwright test tests/visual/",
    "test:visual:ui": "playwright test tests/visual/ --ui",
    
    "lint": "eslint client/src --ext .js,.ts,.vue",
    "lint:fix": "eslint client/src --ext .js,.ts,.vue --fix",
    
    "check:architecture": "node scripts/check-frontend-architecture.mjs",
    
    "check:frontend": "bun run type-check && bun run lint && bun run check:architecture && bun run test:unit",
    
    "ci": "bun run type-check && bun run lint && bun run check:architecture && bun run test:unit",
    "ci:full": "bun run type-check && bun run lint && bun run check:architecture && bun run test:unit && bun run test:e2e && bun run test:a11y"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@iconoir/core": "^7.0.0",
    "@iconoir/vue": "^7.0.0",
    "framework7": "^8.0.0",
    "framework7-vue": "^8.0.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.40.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-vue": "^9.20.0",
    "globals": "^15.0.0",
    "jsdom": "^24.0.0",
    "playwright": "^1.40.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "eslintConfig": "eslint.config.js"
}
