# ANE Server Environment
# Copy to .env and fill in the providers you want to use.
# The router automatically decides which tier (edge / large) handles each message.
# If no keys are set, the entity runs in local-only mode.

# ── Link Processing ──────────────────────────────────────────────────────────
# Google Safe Browsing API v4 — checks user-shared URLs against threat database.
# Get from: https://console.cloud.google.com/ → APIs & Services → Safe Browsing API
# If unset: URL sanitization still runs (protocol + SSRF guard), but no threat lookup.
GOOGLE_SAFE_BROWSING_API_KEY=

# ── Router ────────────────────────────────────────────────────────────────────
# Cloudflare is also used as the LLM classifier for ambiguous routing decisions.
# If CLOUDFLARE_AI_TOKEN is not set, the router uses rules only (still works).

# ── LARGE tier providers (high-fidelity, for complex / emotional tasks) ───────

# Anthropic Claude
# Get from: https://console.anthropic.com/settings/keys
# Default model: claude-sonnet-4-20250514
ANTHROPIC_API_KEY=
CLAUDE_MODEL=

# Google Gemini
# Get from: https://aistudio.google.com/app/apikey
# Default model: gemini-2.0-flash  |  High-quality: gemini-2.5-pro
GEMINI_API_KEY=
GEMINI_MODEL=

# OpenAI
# Get from: https://platform.openai.com/api-keys
# Default model: gpt-4o  |  Budget: gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=

# ── EDGE tier providers (fast, cheap, factual / moderate tasks) ───────────────

# Cloudflare Workers AI
# Account ID: Cloudflare Dashboard → Workers & Pages → Overview → Account ID
# API Token:  Cloudflare Dashboard → My Profile → API Tokens
#             Create token with "Workers AI Read" + "Workers AI Edit" permissions
# Free tier:  10,000 neurons/day (~500 text-gen requests)
# Note: also used as the LLM classifier for ambiguous routing decisions.
CLOUDFLARE_AI_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Ollama (local LLM — fully air-gapped, edge tier)
# Install:    https://ollama.com
# Pull model: ollama pull llama3.2
# Then start: ollama serve (or it runs automatically)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── GIF Keyboard ─────────────────────────────────────────────────────────────
# Klipy — GIF, sticker, clip, and meme API (used here for GIF keyboard only)
# Get a free test key (100 req/min) at: https://klipy.com/developers
# Production key: unlimited requests, requires approval from Klipy.
# If unset: /api/media/* endpoints return 503 and the GIF button is hidden.
KLIPY_API_KEY=

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
ANE_DB_PATH=ane_kernel.sqlite

# CORS — comma-separated list of allowed origins.
# Dev default (when unset): http://localhost:5173, :4173, :3000
# Production: set to your actual frontend domain, e.g. https://ane.yourdomain.com
ALLOWED_ORIGINS=
